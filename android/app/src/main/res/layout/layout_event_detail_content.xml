<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/detailTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:layout_marginBottom="12dp"
        tools:text="Annual Tech Symposium" />

    <TextView
        android:id="@+id/detailDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="8dp"
        tools:text="October 24, 2024" />

    <TextView
        android:id="@+id/detailLocation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="8dp"
        tools:text="Grand Hall, Campus" />

    <TextView
        android:id="@+id/detailCapacity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#757575"
        android:layout_marginBottom="16dp"
        tools:text="Capacity: 150" />

    <TextView
        android:id="@+id/detailDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="#424242"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="24dp"
        tools:text="Join us for a day of innovation and discovery at our annual Tech Symposium. We've invited industry experts to share their insights on the latest trends in software development and artificial intelligence." />

</LinearLayout>
